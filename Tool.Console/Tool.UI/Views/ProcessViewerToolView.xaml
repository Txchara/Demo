<UserControl x:Class="Tool.UI.Views.ProcessViewerToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel LastChildFill="False">
            <Button x:Name="RefreshButton"
                    DockPanel.Dock="Right"
                    Width="120"
                    Height="36"
                    Click="RefreshButton_Click"
                    Content="刷新列表" />

            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <CheckBox x:Name="OnlyWithWindowCheckBox"
                          Margin="0,0,16,0"
                          VerticalAlignment="Center"
                          Checked="OnlyWithWindowCheckBox_Changed"
                          Unchecked="OnlyWithWindowCheckBox_Changed"
                          Content="只看有窗口的进程" />

                <TextBlock VerticalAlignment="Center"
                           Text="排序字段" />
                <ComboBox x:Name="SortFieldComboBox"
                          Width="110"
                          Margin="8,0,16,0"
                          SelectionChanged="SortOption_Changed">
                    <ComboBoxItem Content="PID" />
                    <ComboBoxItem Content="内存占用" />
                </ComboBox>

                <TextBlock VerticalAlignment="Center"
                           Text="排序方式" />
                <ComboBox x:Name="SortOrderComboBox"
                          Width="90"
                          Margin="8,0,16,0"
                          SelectionChanged="SortOption_Changed">
                    <ComboBoxItem Content="正序" />
                    <ComboBoxItem Content="倒序" />
                </ComboBox>

                <TextBlock VerticalAlignment="Center"
                           Text="搜索" />
                <TextBox x:Name="SearchTextBox"
                         Width="180"
                         Margin="8,0,16,0"
                         VerticalContentAlignment="Center"
                         TextChanged="SearchTextBox_TextChanged" />

                <TextBlock x:Name="SummaryTextBlock"
                           VerticalAlignment="Center"
                           Foreground="#6B7280"
                           Text="准备加载进程列表..." />
            </StackPanel>
        </DockPanel>

        <DataGrid x:Name="ProcessDataGrid"
                  Grid.Row="2"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  AlternatingRowBackground="#FAFAFA"
                  RowHeaderWidth="0">
            <DataGrid.Columns>
                <DataGridTextColumn Width="90"
                                    Binding="{Binding ProcessId}"
                                    Header="PID" />
                <DataGridTextColumn Width="180"
                                    Binding="{Binding ProcessName}"
                                    Header="进程名" />
                <DataGridTextColumn Width="110"
                                    Binding="{Binding PriorityClass}"
                                    Header="优先级" />
                <DataGridTextColumn Width="110"
                                    Binding="{Binding WorkingSetMb, StringFormat=F2}"
                                    Header="内存(MB)" />
                <DataGridTextColumn Width="160"
                                    Binding="{Binding StartTimeText}"
                                    Header="启动时间" />
                <DataGridTextColumn Width="2*"
                                    Binding="{Binding Remark}"
                                    Header="备注" />
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
