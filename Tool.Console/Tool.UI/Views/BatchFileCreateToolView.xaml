<UserControl x:Class="Tool.UI.Views.BatchFileCreateToolView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="0,0,4,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 表单区 -->
        <Border Padding="12"
                Background="#FBFBFC"
                BorderBrush="#E5E7EB"
                BorderThickness="1"
                CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="8" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Excel 路径 -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="Excel 路径" />
                    <TextBox x:Name="ExcelPathTextBox"
                             Grid.Column="2"
                             Height="32"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="BrowseExcelButton"
                            Grid.Column="4"
                            Height="32"
                            Click="BrowseExcelButton_Click"
                            Content="选择文件" />
                    <Button x:Name="GenerateTemplateButton"
                            Grid.Column="6"
                            Height="32"
                            Click="GenerateTemplateButton_Click"
                            Content="生成示例表格" />
                    <TextBlock x:Name="ImportStatusTextBlock"
                               Grid.Column="8"
                               VerticalAlignment="Center"
                               Foreground="#6B7280"
                               TextTrimming="CharacterEllipsis" />
                </Grid>

                <!-- 保存位置 -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="120" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="保存位置" />
                    <TextBox x:Name="TargetDirectoryTextBox"
                             Grid.Column="2"
                             Height="32"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="UseExcelDirectoryButton"
                            Grid.Column="4"
                            Height="32"
                            Click="UseExcelDirectoryButton_Click"
                            Content="用 Excel 同文件夹" />
                </Grid>

                <!-- 文件类型 + 数量 + 读取模板 + 开始生成 -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="160" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="16" />
                        <ColumnDefinition Width="90" />
                        <ColumnDefinition Width="8" />
                        <ColumnDefinition Width="110" />
                        <ColumnDefinition Width="12" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0"
                               VerticalAlignment="Center"
                               Text="文件类型" />
                    <ComboBox x:Name="ExtensionComboBox"
                              Grid.Column="2"
                              Height="32"
                              IsEditable="True"
                              VerticalContentAlignment="Center">
                        <ComboBoxItem Content="文本 (.txt)" Tag=".txt" />
                        <ComboBoxItem Content="表格 (.xlsx)" Tag=".xlsx" />
                        <ComboBoxItem Content="Word 文档 (.docx)" Tag=".docx" />
                        <ComboBoxItem Content="网页 (.html)" Tag=".html" />
                        <ComboBoxItem Content="PDF (.pdf)" Tag=".pdf" />
                        <ComboBoxItem Content="图片 (.png)" Tag=".png" />
                        <ComboBoxItem Content="CSV (.csv)" Tag=".csv" />
                    </ComboBox>
                    <TextBlock Grid.Column="4"
                               VerticalAlignment="Center"
                               Text="数量" />
                    <TextBox x:Name="CountTextBox"
                             Grid.Column="6"
                             Height="32"
                             VerticalContentAlignment="Center" />
                    <Button x:Name="ImportNamesButton"
                            Grid.Column="8"
                            Height="32"
                            Click="ImportNamesButton_Click"
                            Content="读取模板" />
                    <Button x:Name="CreateFilesButton"
                            Grid.Column="10"
                            Height="32"
                            Click="CreateFilesButton_Click"
                            Content="开始生成文件" />
                    <TextBlock x:Name="CreateSummaryTextBlock"
                               Grid.Column="12"
                               VerticalAlignment="Center"
                               Foreground="#6B7280"
                               TextTrimming="CharacterEllipsis" />
                </Grid>
            </Grid>
        </Border>

        <!-- 预览 + 结果 -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Padding="12"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock x:Name="ImportedCountTextBlock"
                               FontWeight="SemiBold"
                               Text="还没有读到文件名" />
                    <ListBox x:Name="PreviewListBox"
                             Grid.Row="2"
                             BorderThickness="0"
                             Background="#FAFAFA"
                             FontFamily="Consolas" />
                </Grid>
            </Border>

            <Border Grid.Column="2"
                    Padding="12"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="8" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock FontWeight="SemiBold"
                               Text="生成结果" />
                    <TextBox x:Name="ResultTextBox"
                             Grid.Row="2"
                             IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"
                             TextWrapping="Wrap"
                             FontFamily="Consolas" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
