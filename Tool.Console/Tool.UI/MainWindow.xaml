<Window x:Class="Tool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="900"
        Height="560"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterScreen"
        Icon="convertico-Icon.ico">
    <Grid Background="#F6F7F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- App 名称，右键弹出菜单 -->
                <TextBlock x:Name="AppTitleTextBlock"
                           Grid.Row="0"
                           Padding="10,8"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Text="工具箱"
                           Cursor="Hand">
                    <TextBlock.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="服务设置"
                                      Click="SettingsMenuItem_Click" />
                        </ContextMenu>
                    </TextBlock.ContextMenu>
                </TextBlock>

                <ListBox x:Name="ToolListBox"
                         Grid.Row="2"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="ToolListBox_SelectionChanged">
                    <ListBoxItem Tag="Ping" Padding="10,8">
                        <TextBlock FontSize="14" Text="Ping 工具" />
                    </ListBoxItem>
                    <ListBoxItem Tag="SystemInfo" Padding="10,8">
                        <TextBlock FontSize="14" Text="系统信息" />
                    </ListBoxItem>
                    <ListBoxItem Tag="Temperature" Padding="10,8">
                        <TextBlock FontSize="14" Text="温度监控" />
                    </ListBoxItem>
                    <ListBoxItem Tag="MacAddress" Padding="10,8">
                        <TextBlock FontSize="14" Text="MAC 地址" />
                    </ListBoxItem>
                    <ListBoxItem Tag="LocalIp" Padding="10,8">
                        <TextBlock FontSize="14" Text="本机 IP" />
                    </ListBoxItem>
                    <ListBoxItem Tag="ProcessViewer" Padding="10,8">
                        <TextBlock FontSize="14" Text="查看进程" />
                    </ListBoxItem>
                    <ListBoxItem Tag="BatchFileCreate" Padding="10,8">
                        <TextBlock FontSize="14" Text="批量创建文件" />
                    </ListBoxItem>
                    <ListBoxItem Tag="StartupItem" Padding="10,8">
                        <TextBlock FontSize="14" Text="启动项管理" />
                    </ListBoxItem>
                    <ListBoxItem Tag="FileInfo" Padding="10,8">
                        <TextBlock FontSize="14" Text="文件信息" />
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Border Padding="18"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="10">
                <ContentControl x:Name="ToolContentHost" />
            </Border>
        </Grid>
    </Grid>
</Window>
