<Window x:Class="Tool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工具箱"
        Width="900"
        Height="560"
        MinWidth="760"
        MinHeight="480"
        WindowStartupLocation="CenterScreen">
    <Grid Background="#F6F7F9">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Background="White"
                BorderBrush="#E5E7EB"
                BorderThickness="0,0,1,0">
            <Grid Margin="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="12" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel>
                    <TextBlock FontSize="22"
                               FontWeight="SemiBold"
                               Text="工具箱" />
                    <TextBlock Margin="0,6,0,0"
                               Foreground="#6B7280"
                               Text="选择左侧工具，在右侧查看和操作。" />
                </StackPanel>

                <ListBox x:Name="ToolListBox"
                         Grid.Row="2"
                         BorderThickness="0"
                         Background="Transparent"
                         SelectionChanged="ToolListBox_SelectionChanged">
                    <ListBoxItem Tag="Ping" Padding="10,8">
                        <TextBlock FontSize="14" Text="Ping 工具" />
                    </ListBoxItem>
                    <ListBoxItem Tag="SystemInfo" Padding="10,8">
                        <TextBlock FontSize="14" Text="系统信息" />
                    </ListBoxItem>
                    <ListBoxItem Tag="Temperature" Padding="10,8">
                        <TextBlock FontSize="14" Text="温度监控" />
                    </ListBoxItem>
                    <ListBoxItem Tag="MacAddress" Padding="10,8">
                        <TextBlock FontSize="14" Text="MAC 地址" />
                    </ListBoxItem>
                    <ListBoxItem Tag="LocalIp" Padding="10,8">
                        <TextBlock FontSize="14" Text="本机 IP" />
                    </ListBoxItem>
                </ListBox>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="ToolTitleTextBlock"
                           FontSize="24"
                           FontWeight="SemiBold"
                           Text="Ping 工具" />
                <TextBlock x:Name="ToolDescriptionTextBlock"
                           Margin="0,6,0,0"
                           Foreground="#6B7280"
                           Text="输入地址并执行网络连通性检测。" />
            </StackPanel>

            <Border Grid.Row="2"
                    Padding="18"
                    Background="White"
                    BorderBrush="#E5E7EB"
                    BorderThickness="1"
                    CornerRadius="10">
                <ContentControl x:Name="ToolContentHost" />
            </Border>
        </Grid>
    </Grid>
</Window>
