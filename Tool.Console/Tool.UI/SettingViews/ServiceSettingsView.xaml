<UserControl x:Class="Tool.UI.SettingViews.ServiceSettingsView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <DockPanel LastChildFill="False">
            <Button x:Name="AddButton"
                      DockPanel.Dock="Left"
                      Width="80"
                      Height="32"
                      Margin="0,0,8,0"
                      Click="AddButton_Click"
                      Content="添加规则" />
            <Button x:Name="DeleteButton"
                      DockPanel.Dock="Left"
                      Width="80"
                      Height="32"
                      IsEnabled="False"
                      Click="DeleteButton_Click"
                      Content="删除规则" />
            <TextBlock x:Name="ConfigPathTextBlock"
                         DockPanel.Dock="Right"
                         VerticalAlignment="Center"
                         Foreground="#6B7280"
                         FontSize="11"
                         Text="" />
        </DockPanel>

        <!-- 规则列表 -->
        <DataGrid x:Name="RulesDataGrid"
                    Grid.Row="2"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    SelectionMode="Single"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    AlternatingRowBackground="#FAFAFA"
                    RowHeaderWidth="0"
                    SelectionChanged="RulesDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <!-- 关键字：直接在单元格内编辑 -->
                <DataGridTextColumn Width="200"
                                      Header="进程名关键字"
                                      Binding="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />
                <!-- 限制优先级开关 -->
                <DataGridTemplateColumn Width="120"
                                          Header="限制优先级">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding LimitPriority, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- 限制亲和性开关 -->
                <DataGridTemplateColumn Width="120"
                                          Header="限制CPU相关性">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding LimitAffinity, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- 启用开关 -->
                <DataGridTemplateColumn Width="80"
                                          Header="启用">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="2*"
                                      Header="说明（仅供参考，不影响逻辑）"
                                      Binding="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部保存栏 -->
        <DockPanel Grid.Row="4"
                     LastChildFill="False">
            <TextBlock x:Name="StatusTextBlock"
                         DockPanel.Dock="Left"
                         VerticalAlignment="Center"
                         Foreground="#6B7280"
                         Text="" />
            <Button x:Name="SaveButton"
                      DockPanel.Dock="Right"
                      Width="100"
                      Height="32"
                      Click="SaveButton_Click"
                      Content="保存" />
        </DockPanel>
    </Grid>
</UserControl>
