<UserControl x:Class="Tool.UI.SettingViews.ServiceSettingsView"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="14" />
            <RowDefinition Height="*" />
            <RowDefinition Height="14" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 服务控制栏 -->
        <Border Background="#F3F4F6" CornerRadius="4" Padding="12,8">
            <DockPanel LastChildFill="False">
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="服务状态：" VerticalAlignment="Center" FontSize="13" />
                    <TextBlock x:Name="ServiceStatusText"
                               VerticalAlignment="Center"
                               FontSize="13"
                               FontWeight="SemiBold"
                               Text="检测中..." />
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button x:Name="InstallServiceButton"
                            Width="80" Height="30" Margin="0,0,8,0"
                            Click="InstallServiceButton_Click"
                            Content="安装服务" />
                    <Button x:Name="UninstallServiceButton"
                            Width="80" Height="30" Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="UninstallServiceButton_Click"
                            Content="卸载服务" />
                    <Button x:Name="StartServiceButton"
                            Width="80" Height="30" Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="StartServiceButton_Click"
                            Content="启动服务" />
                    <Button x:Name="StopServiceButton"
                            Width="80" Height="30" Margin="0,0,8,0"
                            IsEnabled="False"
                            Click="StopServiceButton_Click"
                            Content="停止服务" />
                    <Button x:Name="RefreshServiceButton"
                            Width="60" Height="30"
                            Click="RefreshServiceButton_Click"
                            Content="刷新" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- 顶部工具栏 -->
        <DockPanel Grid.Row="2" LastChildFill="False">
            <Button x:Name="AddButton"
                      DockPanel.Dock="Left"
                      Width="80"
                      Height="32"
                      Margin="0,0,8,0"
                      Click="AddButton_Click"
                      Content="添加规则" />
            <Button x:Name="DeleteButton"
                      DockPanel.Dock="Left"
                      Width="80"
                      Height="32"
                      IsEnabled="False"
                      Click="DeleteButton_Click"
                      Content="删除规则" />
        </DockPanel>

        <!-- 规则列表 -->
        <DataGrid x:Name="RulesDataGrid"
                    Grid.Row="4"
                    AutoGenerateColumns="False"
                    CanUserAddRows="False"
                    CanUserDeleteRows="False"
                    CanUserReorderColumns="False"
                    CanUserSortColumns="False"
                    SelectionMode="Single"
                    GridLinesVisibility="Horizontal"
                    HeadersVisibility="Column"
                    AlternatingRowBackground="#FAFAFA"
                    RowHeaderWidth="0"
                    SelectionChanged="RulesDataGrid_SelectionChanged">
            <DataGrid.Columns>
                <!-- 关键字：直接在单元格内编辑 -->
                <DataGridTextColumn Width="200"
                                      Header="进程名关键字"
                                      Binding="{Binding Keyword, UpdateSourceTrigger=PropertyChanged}" />
                <!-- 限制优先级开关 -->
                <DataGridTemplateColumn Width="120"
                                          Header="限制优先级">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding LimitPriority, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- 限制亲和性开关 -->
                <DataGridTemplateColumn Width="120"
                                          Header="限制CPU相关性">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding LimitAffinity, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <!-- 启用开关 -->
                <DataGridTemplateColumn Width="80"
                                          Header="启用">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox IsChecked="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Width="2*"
                                      Header="说明（仅供参考，不影响逻辑）"
                                      Binding="{Binding Remark, UpdateSourceTrigger=PropertyChanged}" />
            </DataGrid.Columns>
        </DataGrid>

        <!-- 底部保存栏 -->
        <DockPanel Grid.Row="6"
                     LastChildFill="False">
            <TextBlock x:Name="StatusTextBlock"
                         DockPanel.Dock="Left"
                         VerticalAlignment="Center"
                         Foreground="#6B7280"
                         Text="" />
            <Button x:Name="SaveButton"
                      DockPanel.Dock="Right"
                      Width="100"
                      Height="32"
                      Click="SaveButton_Click"
                      Content="保存" />
            <TextBlock x:Name="ConfigPathTextBlock"
                         DockPanel.Dock="Right"
                         VerticalAlignment="Center"
                         Foreground="#6B7280"
                         FontSize="11"
                         Margin="0,0,12,0"
                         Text="" />
        </DockPanel>
    </Grid>
</UserControl>
